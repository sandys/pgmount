FROM rust:1.85-bookworm

# Install FUSE and PostgreSQL dev libraries
RUN apt-get update && apt-get install -y \
    libfuse3-dev \
    fuse3 \
    pkg-config \
    libpq-dev \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Allow FUSE in container (for testing)
RUN echo "user_allow_other" >> /etc/fuse.conf

WORKDIR /workspace

# Keep container running
CMD ["sleep", "infinity"]
